{
  "name": "hermes-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "push": "git add -A && git commit -m \"update\" && git push origin main",
    "sync": "bash scripts/watch-and-sync.sh",
    "dist:mac": "next build && npx electron-builder --mac"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "15.1.6",
    "react": "^18",
    "react-dom": "^18",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^8",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.hermes.studio",
    "productName": "Hermes Studio",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "next.config.ts",
      "tailwind.config.js",
      "postcss.config.mjs"
    ]
  }
}
